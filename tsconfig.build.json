{
  "compilerOptions": {
    "module": "Node20",
    "target": "ES2023",
    "lib": ["ES2023"],
    "declaration": true,
    "sourceMap": false,
    "strict": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "outDir": "./dist"
  },
  "include": ["src/**/*"],
  "exclude": [
    "**/node_modules",
    "**/dist"
  ]
}
