{
  "name": "@mikro-orm/nestjs",
  "type": "module",
  "version": "7.0.0-dev.0",
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts"
  },
  "license": "MIT",
  "author": {
    "name": "Martin Adamek",
    "email": "banan23@gmail.com"
  },
  "keywords": [
    "nestjs",
    "mikro-orm",
    "orm",
    "mongo",
    "mongodb",
    "mysql",
    "postgresql",
    "sqlite",
    "entity",
    "ddd",
    "mikro-orm",
    "unit-of-work",
    "data-mapper",
    "identity-map"
  ],
  "description": "NestJS module for MikroORM",
  "homepage": "https://github.com/mikro-orm/nestjs#readme",
  "bugs": "https://github.com/mikro-orm/nestjs/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/mikro-orm/nestjs"
  },
  "readme": "./README.md",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && cp package.json README.md dist/",
    "test": "vitest --run",
    "tsc-check-tests": "tsc --noEmit --project tests/tsconfig.json",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 1",
    "release": "yarn build && cd dist && npm publish && cd ..",
    "coverage": "yarn test --coverage",
    "lint": "eslint src/**/*.ts"
  },
  "peerDependencies": {
    "@mikro-orm/core": "^7.0.0 || ^7.0.0-dev.105",
    "@nestjs/common": "^11.0.5",
    "@nestjs/core": "^11.0.5",
    "reflect-metadata": "^0.1.0 || ^0.2.0"
  },
  "devDependencies": {
    "@mikro-orm/core": "^7.0.0-dev.105",
    "@mikro-orm/decorators": "^7.0.0-dev.105",
    "@mikro-orm/sqlite": "^7.0.0-dev.105",
    "@nestjs/common": "^11.1.9",
    "@nestjs/core": "^11.1.9",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/testing": "^11.1.9",
    "@stylistic/eslint-plugin": "^5.6.1",
    "@swc/core": "^1.15.4",
    "@types/node": "^25.0.1",
    "@types/supertest": "^6.0.3",
    "conventional-changelog": "^7.1.1",
    "conventional-changelog-cli": "^5.0.0",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "supertest": "^7.1.4",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.49.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.0.15"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.ts": [
      "eslint src/**/*.ts --fix"
    ]
  },
  "renovate": {
    "extends": [
      "config:base",
      ":preserveSemverRanges",
      ":semanticCommitTypeAll(chore)"
    ],
    "semanticCommits": "enabled",
    "separateMajorMinor": false,
    "dependencyDashboard": false,
    "packageRules": [
      {
        "matchUpdateTypes": [
          "patch",
          "minor"
        ],
        "groupName": "patch/minor dependencies",
        "groupSlug": "all-non-major",
        "automerge": true,
        "automergeType": "branch"
      }
    ],
    "schedule": [
      "every weekday"
    ]
  },
  "engines": {
    "node": ">= 22.17.0"
  },
  "packageManager": "yarn@4.12.0"
}
